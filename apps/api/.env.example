NODE_ENV=development
PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=modaia
DB_PASSWORD=modaia_dev_password
DB_DATABASE=modaia_closet

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000
WEB_APP_URL=http://localhost:3000

# Wompi (pagos) — sin cuenta real configurada, el checkout arma el link igual
# (sin firma de integridad) y hay un endpoint /payments/dev/simulate/:orderId
# para probar el flujo completo en desarrollo sin credenciales.
WOMPI_PUBLIC_KEY=pub_test_replace_with_real_sandbox_key
WOMPI_INTEGRITY_SECRET=
WOMPI_EVENTS_SECRET=
WOMPI_CHECKOUT_URL=https://checkout.wompi.co/p/

# SerpApi (Google Trends) — sin SERPAPI_KEY, /trends devuelve un dataset de ejemplo
# etiquetado como tal. Con la clave, TrendsService consulta interés de búsqueda real
# (Colombia, últimos 7 días) para una lista curada de términos de moda.
SERPAPI_KEY=
SERPAPI_TRENDS_GEO=CO

# OpenAI — sin OPENAI_API_KEY, el generador de marketing usa plantillas y el chatbot
# usa reglas por palabras clave (ambos siguen siendo funcionales). Con la clave, los
# dos usan un modelo real; la búsqueda de productos del chatbot sigue siendo siempre
# una consulta real a la base de datos, nunca inventada por el modelo.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure (producción - no requerido en local)
AZURE_KEY_VAULT_URL=
AZURE_STORAGE_CONNECTION_STRING=
AZURE_ENTRA_TENANT_ID=
AZURE_ENTRA_CLIENT_ID=
