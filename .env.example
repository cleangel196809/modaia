# docker-compose.yml lee estas variables de un archivo ".env" en esta misma carpeta
# (creado por ti, nunca se sube a git — ver .gitignore). Copia este archivo a ".env"
# y completa las claves reales que quieras activar. Sin ellas, Trends/Marketing/
# Chatbot siguen funcionando en modo mock/plantillas/reglas — ver docs/ARCHITECTURE.md.

SERPAPI_KEY=
SERPAPI_TRENDS_GEO=CO

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
